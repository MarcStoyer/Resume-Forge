{
  "name": "resume-forge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A local résumé builder: master bullet bank, whole-job toggles, CV upload/parse, AI + web-search drafting, job-description bullet matcher, multiple templates, ATS-friendly PDF export.",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,green \"vite\" \"node server/index.js\"",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mammoth": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "vite": "^5.4.0"
  }
}
